# Ingreso laboral por hora promedio segun dimensiones
library(readxl)
library(dplyr)
library(purrr)
library(ggplot2)
library(scales)
library(stringr)
library(readr)
library(tibble)
setwd("~/Trabajo-Profesional/Javeriana")
ruta_graficos <- "Paper\figures"  # <-- cambia esta ruta por la que tú quieras
options(scipen = 999)
library(haven)
library(dplyr)
library(fixest)
geih <- read_dta(
"Datos/Processed/GEIH_base_modelo_celdas_2008_2025.dta"
)
geih <- geih %>%
mutate(
anio = as.factor(anio),
sector = as.factor(sector),
tamano_empresa = as.factor(tamano_empresa),
educacion = as.factor(educacion),
sexo = as.factor(sexo),
formalidad = as.factor(formalidad),
mujer = as.numeric(mujer),
formal = as.numeric(formal),
fex = as.numeric(fex),
log_ingreso_hora_real = as.numeric(log_ingreso_hora_real),
observaciones = as.numeric(observaciones)
)
m1 <- feols(
log_ingreso_hora_real ~
i(tamano_empresa, ref = "2-3") +
mujer +
i(educacion, ref = "Básica secundaria") +
i(formalidad, ref = "Informal") |
sector^anio,
weights = ~ fex,
cluster = ~ sector,
data = geih
)
summary(m1)
library(haven)
library(dplyr)
library(fixest)
library(broom)
library(stringr)
library(ggplot2)
library(scales)
geih <- geih %>%
mutate(
anio = as.integer(anio),
anio_f = factor(anio),
sector = as.factor(sector),
tamano_empresa = as.factor(tamano_empresa),
educacion = as.factor(educacion),
formalidad = as.factor(formalidad),
mujer = as.numeric(mujer),
formal = as.numeric(formal),
fex = as.numeric(fex),
log_ingreso_hora_real = as.numeric(log_ingreso_hora_real),
observaciones = as.numeric(observaciones)
) %>%
filter(
!is.na(log_ingreso_hora_real),
!is.na(tamano_empresa),
!is.na(educacion),
!is.na(mujer),
!is.na(formal),
!is.na(sector),
!is.na(fex),
fex > 0,
observaciones >= 30
)
m1 <- feols(
log_ingreso_hora_real ~
i(tamano_empresa, ref = "2-3") +
mujer +
i(educacion, ref = "Básica secundaria") +
formal |
sector^anio,
weights = ~ fex,
cluster = ~ sector,
data = geih
)
summary(m1)
betas_m1 <- tidy(m1, conf.int = TRUE, conf.level = 0.95) %>%
filter(str_detect(term, "^tamano_empresa::")) %>%
mutate(
tamano_empresa = str_remove(term, "^tamano_empresa::"),
premium = 100 * (exp(estimate) - 1),
ci_low = 100 * (exp(conf.low) - 1),
ci_high = 100 * (exp(conf.high) - 1),
significativo = ci_low > 0 | ci_high < 0,
tamano_empresa = factor(
tamano_empresa,
levels = c(
"Solo", "4-5", "6-10", "11-19",
"20-30", "31-50", "51-100", "101+"
)
)
) %>%
arrange(tamano_empresa)
g_premium_m1 <- ggplot(
betas_m1,
aes(x = tamano_empresa, y = premium)
) +
geom_hline(
yintercept = 0,
linetype = "dashed",
color = "gray45"
) +
geom_errorbar(
aes(ymin = ci_low, ymax = ci_high, color = significativo),
width = 0.15,
linewidth = 0.9
) +
geom_point(
aes(color = significativo),
size = 3.5
) +
geom_label(
aes(label = paste0(round(premium, 1), "%")),
fill = "black",
color = "white",
fontface = "bold",
size = 3.8,
vjust = -0.8,
show.legend = FALSE
) +
scale_color_manual(
values = c(
"TRUE" = "darkblue",
"FALSE" = "gray55"
),
labels = c(
"TRUE" = "Significativo 5%",
"FALSE" = "No significativo"
)
) +
scale_y_continuous(
labels = function(x) paste0(x, "%"),
expand = expansion(mult = c(0.12, 0.18))
) +
labs(
x = "Tamaño de empresa",
y = "Premium salarial frente a empresas de 2-3 trabajadores (%)",
title = "Firm size wage premium en Colombia",
subtitle = "Coeficientes estimados con intervalos de confianza al 95%",
color = NULL
) +
theme_classic(base_size = 13) +
theme(
plot.title = element_text(face = "bold", size = 15),
plot.subtitle = element_text(size = 11),
axis.title = element_text(face = "bold"),
axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "bottom"
)
g_premium_m1
m2 <- feols(
log_ingreso_hora_real ~
i(tamano_empresa, anio_f, ref = "2-3") +
mujer +
i(educacion, ref = "Básica secundaria") +
formal |
sector^anio,
weights = ~ fex,
cluster = ~ sector,
data = geih
)
summary(m2)
betas_m2 <- tidy(m2, conf.int = TRUE, conf.level = 0.95) %>%
filter(
str_detect(term, "tamano_empresa::"),
str_detect(term, "anio_f::")
) %>%
mutate(
tamano_empresa = str_match(term, "tamano_empresa::([^:]+):anio_f::")[, 2],
anio = as.integer(str_match(term, "anio_f::([0-9]{4})")[, 2]),
premium = 100 * (exp(estimate) - 1),
ci_low = 100 * (exp(conf.low) - 1),
ci_high = 100 * (exp(conf.high) - 1),
significativo = ci_low > 0 | ci_high < 0,
tamano_empresa = factor(
tamano_empresa,
levels = c(
"Solo", "4-5", "6-10", "11-19",
"20-30", "31-50", "51-100", "101+"
)
)
) %>%
filter(!is.na(tamano_empresa), !is.na(anio)) %>%
arrange(tamano_empresa, anio)
g_premium_m2 <- ggplot(
betas_m2,
aes(
x = anio,
y = premium,
color = tamano_empresa,
group = tamano_empresa
)
) +
geom_hline(
yintercept = 0,
linetype = "dashed",
color = "gray45"
) +
geom_line(linewidth = 1) +
geom_point(size = 2.5) +
geom_ribbon(
aes(ymin = ci_low, ymax = ci_high, fill = tamano_empresa),
alpha = 0.12,
color = NA
) +
scale_y_continuous(
labels = function(x) paste0(x, "%")
) +
scale_x_continuous(
breaks = sort(unique(betas_m2$anio))
) +
labs(
x = "Año",
y = "Premium salarial frente a empresas de 2-3 trabajadores (%)",
title = "Evolución del firm size wage premium en Colombia",
subtitle = "Coeficientes por año con intervalos de confianza al 95%",
color = "Tamaño de empresa",
fill = "Tamaño de empresa"
) +
theme_classic(base_size = 13) +
theme(
plot.title = element_text(face = "bold", size = 15),
plot.subtitle = element_text(size = 11),
axis.title = element_text(face = "bold"),
axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "bottom"
)
g_premium_m2
